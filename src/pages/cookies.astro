---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Cookie Policy" description="News Lancashire does not use cookies.">
  <section class="hero" style="padding-bottom: 1rem;">
    <h1 class="hero-headline">Cookie Policy</h1>
  </section>
  <div class="article-body">
    <p>This website does not use cookies. No first-party cookies. No third-party cookies. No tracking cookies.</p>
    <p>We use Cloudflare Web Analytics which operates without cookies or any form of client-side storage.</p>
  </div>
</BaseLayout>
