---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getBoroughName } from "../../data/boroughs";
import { getCategoryName, getCategoryColour } from "../../data/categories";
import { formatDate, readingTime, SITE_URL, type StructuredDataNode } from "../../lib/site";
import { articleSlug } from "../../lib/articles";
import { categoryImage } from "../../lib/images";

export const getStaticPaths: GetStaticPaths = async () => {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { borough: article.data.borough, slug: articleSlug(article) },
    props: { article },
  }));
};

const { article } = Astro.props;
const { Content } = await article.render();
const boroughName = getBoroughName(article.data.borough);
const categoryName = getCategoryName(article.data.category);

const structuredData: StructuredDataNode[] = [
  {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    headline: article.data.headline,
    description: article.data.summary,
    datePublished: article.data.date,
    ...(article.data.updated && { dateModified: article.data.updated }),
    author: {
      "@type": "Organization",
      name: "News Lancashire",
      url: SITE_URL,
    },
    publisher: {
      "@id": `${SITE_URL}/#organization`,
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${SITE_URL}/${article.data.borough}/${articleSlug(article)}/`,
    },
    articleSection: categoryName,
    inLanguage: "en-GB",
    image: `${SITE_URL}/og/${article.data.borough}/${articleSlug(article)}.png`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: SITE_URL,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: boroughName,
        item: `${SITE_URL}/${article.data.borough}/`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.data.headline,
      },
    ],
  },
];
---

<BaseLayout
  title={article.data.headline}
  description={article.data.summary}
  image={`/og/${article.data.borough}/${articleSlug(article)}.png`}
  ogType="article"
  articleDate={article.data.date}
  articleSection={categoryName}
  newsKeywords={`${boroughName}, ${categoryName}, Lancashire`}
  structuredData={structuredData}
>
  <article style="padding-top: 1.5rem;">
    <div class="breadcrumbs">
      <a href="/">Home</a>
      <span class="separator">/</span>
      <a href={`/${article.data.borough}/`}>{boroughName}</a>
      <span class="separator">/</span>
      <span>Article</span>
    </div>

    <header style="margin-bottom: 2rem;">
      <div class="article-card-meta" style="margin-bottom: 0.75rem;">
        <a href={`/${article.data.borough}/`} class="badge badge-borough" style="text-decoration: none;">
          {boroughName}
        </a>
        <span class="badge badge-category" style={`color: ${getCategoryColour(article.data.category)}`}>
          {categoryName}
        </span>
        {article.data.content_tier === "investigation" && (
          <span class="badge badge-investigation">Investigation</span>
        )}
      </div>

      <h1 style="font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.02em; margin: 0 0 0.75rem;">
        {article.data.headline}
      </h1>

      <p style="font-size: 1.05rem; color: var(--muted); line-height: 1.5; margin: 0 0 1rem; max-width: 680px;">
        {article.data.summary}
      </p>

      <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; font-size: 0.82rem; color: var(--muted);">
        <time datetime={article.data.date}>{formatDate(article.data.date)}</time>
        <span>&middot;</span>
        <a href={article.data.source_url} class="source-pill" target="_blank" rel="noopener noreferrer">
          {article.data.source} &nearr;
        </a>
        {article.data.fact_check_score && (
          <>
            <span>&middot;</span>
            <span style={`color: ${article.data.fact_check_score >= 70 ? "var(--success)" : "var(--warning)"}`}>
              Fact-check: {article.data.fact_check_score}%
            </span>
          </>
        )}
      </div>
    </header>

    <div class="article-hero">
      <img
        src={categoryImage(article.data.category)}
        alt={article.data.image_alt || `${categoryName} news in ${boroughName}`}
        loading="eager"
        decoding="async"
        width="800"
        height="450"
      />
      <span class="article-hero-credit">Image: Unsplash</span>
    </div>

    <div class="article-body">
      <Content />
    </div>

    <!-- Share buttons -->
    <div class="article-share">
      <span class="article-share__label">Share</span>
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.data.headline)}&url=${encodeURIComponent(`${SITE_URL}/${article.data.borough}/${articleSlug(article)}/`)}`}
        target="_blank" rel="noopener noreferrer"
        class="article-share__btn"
        aria-label="Share on X"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a
        href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`${SITE_URL}/${article.data.borough}/${articleSlug(article)}/`)}`}
        target="_blank" rel="noopener noreferrer"
        class="article-share__btn"
        aria-label="Share on Facebook"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <button
        class="article-share__btn"
        aria-label="Copy link"
        onclick="navigator.clipboard.writeText(window.location.href).then(()=>{this.textContent='Copied!';setTimeout(()=>{this.innerHTML='<svg width=\\'16\\' height=\\'16\\' viewBox=\\'0 0 24 24\\' fill=\\'none\\' stroke=\\'currentColor\\' stroke-width=\\'2\\'><rect x=\\'9\\' y=\\'9\\' width=\\'13\\' height=\\'13\\' rx=\\'2\\'/><path d=\\'M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1\\'/></svg>'},2000)})"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
      </button>
    </div>

    <footer style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border);">
      <div class="section-head" style="border-bottom: none;">
        <h2>More from {boroughName}</h2>
        <a href={`/${article.data.borough}/`} class="section-head__link">All {boroughName} news &rarr;</a>
      </div>
    </footer>
  </article>
</BaseLayout>
