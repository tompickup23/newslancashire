---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { BOROUGHS, getBoroughName } from "../data/boroughs";
import { getCategoryName, getCategoryColour, CATEGORIES } from "../data/categories";
import { relativeTime } from "../lib/site";
import { articlePath } from "../lib/articles";
import { selectImage } from "../lib/images";

const allArticles = await getCollection("articles");
const sorted = allArticles.sort((a, b) => b.data.date.localeCompare(a.data.date));

// Hero: lead story + 2 secondary
const hero = sorted[0];
const heroSecondary = sorted.slice(1, 3);

// Latest news: next 8 articles for the carousel
const latest = sorted.slice(3, 11);

// Topic sections: group by category, pick top categories with enough articles
const byCategory = new Map<string, typeof allArticles>();
for (const a of sorted) {
  const cat = a.data.category;
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(a);
}
const topicOrder = ["crime", "politics", "health", "business", "transport", "education", "sport", "environment", "planning"];
const topicSections = topicOrder
  .filter((cat) => (byCategory.get(cat)?.length || 0) >= 2)
  .slice(0, 5);

// Most read: top 5 by interest score
const mostRead = [...sorted]
  .sort((a, b) => (b.data.interest_score || 0) - (a.data.interest_score || 0))
  .slice(0, 5);

// Investigations
const investigations = sorted
  .filter((a) => a.data.content_tier === "investigation" || a.data.category === "investigation")
  .slice(0, 3);

function tierBadge(tier: string, category: string) {
  if (tier === "investigation" || category === "investigation") return "Investigation";
  if (tier === "analysis") return "Analysis";
  if (category === "data-driven") return "Data";
  return null;
}
---

<BaseLayout title="News Lancashire — Independent Local News">
  <!-- Hero section: lead story + 2 secondary -->
  {hero && (
    <section class="hp-hero">
      <a href={articlePath(hero)} class="hp-hero__lead">
        <img
          src={selectImage(hero.data.category, hero.data.borough, hero.data.headline, hero.data.summary)}
          alt={`${getCategoryName(hero.data.category)} news`}
          class="hp-hero__img"
          loading="eager"
          width="800" height="450"
        />
        <div class="hp-hero__overlay">
          <div class="hp-hero__badges">
            <span class="badge badge-borough">{getBoroughName(hero.data.borough)}</span>
            <span class="badge badge-category" style={`color: ${getCategoryColour(hero.data.category)}`}>
              {getCategoryName(hero.data.category)}
            </span>
            {tierBadge(hero.data.content_tier, hero.data.category) && (
              <span class="badge badge-investigation">{tierBadge(hero.data.content_tier, hero.data.category)}</span>
            )}
          </div>
          <h1 class="hp-hero__title">{hero.data.headline}</h1>
          <p class="hp-hero__summary">{hero.data.summary}</p>
          <span class="hp-hero__time">{relativeTime(hero.data.date)} &middot; {hero.data.source}</span>
        </div>
      </a>
      <div class="hp-hero__sidebar">
        {heroSecondary.map((a) => (
          <a href={articlePath(a)} class="hp-hero__side-card">
            <img
              src={selectImage(a.data.category, a.data.borough, a.data.headline, a.data.summary)}
              alt={`${getCategoryName(a.data.category)} news`}
              class="hp-hero__side-img"
              loading="eager"
              width="400" height="225"
            />
            <div class="hp-hero__side-body">
              <span class="badge badge-borough" style="font-size: 0.6rem;">{getBoroughName(a.data.borough)}</span>
              <h2 class="hp-hero__side-title">{a.data.headline}</h2>
              <span class="hp-hero__side-time">{relativeTime(a.data.date)}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Borough pills -->
  <nav class="borough-pills" aria-label="Browse by borough" style="margin-top: 1.5rem;">
    <a href="/latest/" class="borough-pill" aria-current={undefined}>All Lancashire</a>
    {BOROUGHS.map((b) => (
      <a href={`/${b.slug}/`} class="borough-pill">{b.name}</a>
    ))}
  </nav>

  <!-- Latest news horizontal carousel -->
  {latest.length > 0 && (
    <section style="margin-top: 2rem;">
      <div class="section-head">
        <h2>Latest News</h2>
        <a href="/latest/" class="section-head__link">View all &rarr;</a>
      </div>
      <div class="hp-carousel" role="region" aria-label="Latest news">
        {latest.map((a) => (
          <a href={articlePath(a)} class="hp-carousel__card">
            <img
              src={selectImage(a.data.category, a.data.borough, a.data.headline, a.data.summary)}
              alt={`${getCategoryName(a.data.category)} news`}
              class="hp-carousel__img"
              loading="lazy"
              width="320" height="180"
            />
            <div class="hp-carousel__body">
              <div class="hp-carousel__meta">
                <span class="badge badge-borough" style="font-size: 0.58rem;">{getBoroughName(a.data.borough)}</span>
                <span class="badge badge-category" style={`font-size: 0.58rem; color: ${getCategoryColour(a.data.category)}`}>
                  {getCategoryName(a.data.category)}
                </span>
              </div>
              <h3 class="hp-carousel__title">{a.data.headline}</h3>
              <span class="hp-carousel__time">{relativeTime(a.data.date)}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Main content + sidebar layout -->
  <div class="hp-main-grid" style="margin-top: 2.5rem;">
    <div class="hp-main-content">
      <!-- Topic sections -->
      {topicSections.map((cat) => {
        const catArticles = byCategory.get(cat)!.slice(0, 4);
        return (
          <section class="hp-topic-section">
            <div class="section-head">
              <h2 style={`color: ${getCategoryColour(cat)}`}>{getCategoryName(cat)}</h2>
              <a href={`/${cat}/`} class="section-head__link">More {getCategoryName(cat).toLowerCase()} &rarr;</a>
            </div>
            <div class="hp-topic-grid">
              {catArticles.map((a, i) => (
                <a href={articlePath(a)} class={`hp-topic-card ${i === 0 ? "hp-topic-card--lead" : ""}`}>
                  {i === 0 && (
                    <img
                      src={selectImage(a.data.category, a.data.borough, a.data.headline, a.data.summary)}
                      alt={`${getCategoryName(a.data.category)} news`}
                      class="hp-topic-card__img"
                      loading="lazy"
                      width="400" height="225"
                    />
                  )}
                  <div class="hp-topic-card__body">
                    <span class="badge badge-borough" style="font-size: 0.58rem;">{getBoroughName(a.data.borough)}</span>
                    <h3 class="hp-topic-card__title">{a.data.headline}</h3>
                    {i === 0 && <p class="hp-topic-card__summary">{a.data.summary}</p>}
                    <span class="hp-topic-card__time">{relativeTime(a.data.date)} &middot; {a.data.source}</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        );
      })}

      <!-- Newsletter CTA -->
      <section class="hp-newsletter">
        <div class="hp-newsletter__inner">
          <h2 class="hp-newsletter__title">Get Lancashire news in your inbox</h2>
          <p class="hp-newsletter__text">Weekly digest of the most important stories from your borough. No spam, unsubscribe anytime.</p>
          <form class="hp-newsletter__form" action="/newsletter/" method="get">
            <input type="email" placeholder="your@email.com" class="hp-newsletter__input" aria-label="Email address" />
            <button type="submit" class="hp-newsletter__btn">Subscribe</button>
          </form>
        </div>
      </section>
    </div>

    <!-- Sidebar: Most Read -->
    <aside class="hp-sidebar">
      <div class="hp-sidebar__card">
        <h3 class="hp-sidebar__title">Most Read</h3>
        <ol class="hp-most-read">
          {mostRead.map((a, i) => (
            <li>
              <a href={articlePath(a)} class="hp-most-read__item">
                <span class="hp-most-read__rank">{i + 1}</span>
                <div>
                  <span class="badge badge-borough" style="font-size: 0.55rem; margin-bottom: 2px;">{getBoroughName(a.data.borough)}</span>
                  <div class="hp-most-read__title">{a.data.headline}</div>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </div>

      <!-- About section -->
      <div class="hp-sidebar__card" style="margin-top: 1rem;">
        <h3 class="hp-sidebar__title">About Us</h3>
        <p style="font-size: 0.8rem; color: var(--muted); margin: 0.5rem 0; line-height: 1.5;">
          Independent local journalism for all 14 Lancashire boroughs. No ads. No clickbait. Backed by data and public records.
        </p>
        <a href="/about/" class="source-pill" style="font-size: 0.75rem;">
          Learn more &rarr;
        </a>
      </div>
    </aside>
  </div>

  <!-- Empty state -->
  {allArticles.length === 0 && (
    <div class="empty-state" style="margin-top: 3rem;">
      <strong>Coming soon</strong>
      <p>Quality local journalism for Lancashire. Articles are being prepared.</p>
    </div>
  )}
</BaseLayout>
