---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Newsletter" description="Subscribe to the News Lancashire weekly digest. Quality local news delivered to your inbox.">
  <section class="hero" style="padding-bottom: 1rem;">
    <h1 class="hero-headline">Newsletter</h1>
    <p class="hero-sub">
      A weekly digest of the most important Lancashire news.
      No spam. No ads. Just the stories that matter.
    </p>
  </section>

  <div class="card" style="max-width: 480px; padding: 2rem;">
    <p style="font-size: 0.88rem; color: var(--muted); margin-bottom: 1.25rem;">
      Subscribe to receive a weekly email with the top stories from across Lancashire's 14 boroughs.
    </p>
    <form id="newsletter-form" style="display: flex; flex-direction: column; gap: 0.75rem;">
      <input
        type="email"
        name="email"
        placeholder="Your email address"
        required
        style="padding: 0.65rem 0.85rem; background: var(--bg); border: 1px solid var(--border); border-radius: 12px; color: var(--ink); font-size: 0.95rem; outline: none;"
      />
      <button
        type="submit"
        style="padding: 0.65rem 1.25rem; background: var(--accent); color: #fff; font-weight: 700; font-size: 0.88rem; border: none; border-radius: 12px; cursor: pointer;"
      >
        Subscribe
      </button>
    </form>
    <p style="font-size: 0.72rem; color: var(--muted); margin-top: 0.75rem;">
      We respect your privacy. Unsubscribe at any time. See our <a href="/privacy/">privacy policy</a>.
    </p>
  </div>
</BaseLayout>
