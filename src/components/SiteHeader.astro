---
import { BOROUGHS } from "../data/boroughs";

const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/latest/", label: "Latest" },
  { href: "/politics/", label: "Politics" },
  { href: "/crime/", label: "Crime" },
  { href: "/investigations/", label: "Investigations" },
];
---

<header class="site-header shell-wide">
  <a href="/" class="brand" aria-label="News Lancashire home">
    <img src="/brand/logo.svg" alt="News Lancashire" class="brand-logo" width="260" height="48" />
  </a>

  <div class="desktop-nav">
    <nav class="site-nav" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a href={link.href} aria-current={pathname.startsWith(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))}
    </nav>

    <details class="borough-dropdown">
      <summary class="borough-trigger">Boroughs</summary>
      <div class="borough-panel">
        {BOROUGHS.map((b) => (
          <a href={`/${b.slug}/`}>{b.name}</a>
        ))}
      </div>
    </details>
  </div>

  <div class="site-tools">
    <details class="lang-dropdown">
      <summary class="lang-trigger" aria-label="Translate page">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg>
      </summary>
      <div class="lang-panel">
        <a href="https://translate.google.com/translate?sl=en&tl=ur&u=https://newslancashire.co.uk" target="_blank" rel="noopener">اردو (Urdu)</a>
        <a href="https://translate.google.com/translate?sl=en&tl=pl&u=https://newslancashire.co.uk" target="_blank" rel="noopener">Polski</a>
        <a href="https://translate.google.com/translate?sl=en&tl=ro&u=https://newslancashire.co.uk" target="_blank" rel="noopener">Română</a>
        <a href="https://translate.google.com/translate?sl=en&tl=gu&u=https://newslancashire.co.uk" target="_blank" rel="noopener">ગુજરાતી (Gujarati)</a>
        <a href="https://translate.google.com/translate?sl=en&tl=bn&u=https://newslancashire.co.uk" target="_blank" rel="noopener">বাংলা (Bengali)</a>
        <a href="https://translate.google.com/translate?sl=en&tl=pa&u=https://newslancashire.co.uk" target="_blank" rel="noopener">ਪੰਜਾਬੀ (Punjabi)</a>
        <a href="https://translate.google.com/translate?sl=en&tl=zh-CN&u=https://newslancashire.co.uk" target="_blank" rel="noopener">中文</a>
        <a href="https://translate.google.com/translate?sl=en&tl=ar&u=https://newslancashire.co.uk" target="_blank" rel="noopener">العربية</a>
      </div>
    </details>

    <button
      class="search-launch"
      type="button"
      aria-label="Search articles"
      id="search-trigger"
    >
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <span class="search-shortcut" aria-hidden="true">&#8984;K</span>
    </button>

    <button class="mobile-menu-btn" type="button" aria-label="Open menu" id="mobile-menu-open">
      <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>
</header>

<!-- Mobile drawer -->
<div class="mobile-drawer-backdrop" id="mobile-drawer-backdrop" hidden></div>
<div class="mobile-drawer-panel" id="mobile-drawer-panel" hidden>
  <div class="mobile-drawer-head">
    <span class="mobile-drawer-title">Menu</span>
    <button class="mobile-drawer-close" id="mobile-drawer-close" aria-label="Close menu">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <nav class="mobile-drawer-links" aria-label="Mobile navigation">
    <a href="/">Home</a>
    {navLinks.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
    <hr />
    <span class="mobile-drawer-section">Boroughs</span>
    {BOROUGHS.map((b) => (
      <a href={`/${b.slug}/`}>{b.name}</a>
    ))}
    <hr />
    <a href="/about/">About</a>
    <a href="/newsletter/">Newsletter</a>
  </nav>
</div>

<script>
  const openBtn = document.getElementById("mobile-menu-open");
  const closeBtn = document.getElementById("mobile-drawer-close");
  const backdrop = document.getElementById("mobile-drawer-backdrop");
  const panel = document.getElementById("mobile-drawer-panel");

  function openDrawer() {
    backdrop?.removeAttribute("hidden");
    panel?.removeAttribute("hidden");
  }
  function closeDrawer() {
    backdrop?.setAttribute("hidden", "");
    panel?.setAttribute("hidden", "");
  }

  openBtn?.addEventListener("click", openDrawer);
  closeBtn?.addEventListener("click", closeDrawer);
  backdrop?.addEventListener("click", closeDrawer);

  // Update translate links with current page URL
  document.querySelectorAll('.lang-panel a').forEach(a => {
    const href = a.getAttribute('href');
    if (href) {
      a.setAttribute('href', href.replace('https://newslancashire.co.uk', window.location.href));
    }
  });
</script>
